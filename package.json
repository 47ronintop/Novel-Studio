{
  "name": "novel-studio",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first AI novel creation IDE.",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build:types && npm run build:renderer",
    "build:types": "tsc -b",
    "build:renderer": "vite build --config apps/desktop/vite.config.ts",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "vitest run --passWithNoTests",
    "test:contract": "vitest run packages/schemas/test --passWithNoTests",
    "test:e2e": "playwright test --list --pass-with-no-tests",
    "alpha:check": "npm run build && node scripts/alpha-check.mjs",
    "package:check": "npm run build && node scripts/package-check.mjs",
    "package:artifact-check": "node scripts/artifact-secret-scan.mjs",
    "package:dir": "node scripts/package-dir.mjs"
  },
  "engines": {
    "node": ">=20.20.0",
    "npm": ">=10.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "electron-builder": "^26.15.3",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
