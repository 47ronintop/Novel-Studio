{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "schema.workflow-definition.v1",
  "title": "Workflow Definition",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "type",
    "title",
    "status",
    "entryStepId",
    "steps",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "id": { "type": "string", "pattern": "^wf_[A-Za-z0-9_-]+$" },
    "type": { "const": "workflow.definition" },
    "title": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["active", "draft", "archived", "deleted"] },
    "entryStepId": { "type": "string" },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "kind"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "kind": {
            "type": "string",
            "enum": ["context", "agent", "confirmation", "save", "branch"]
          },
          "agentId": { "type": "string" },
          "nextStepId": { "type": "string" },
          "branches": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "label", "condition", "nextStepId"],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "label": { "type": "string", "minLength": 1 },
                "condition": { "type": "string", "minLength": 1 },
                "nextStepId": { "type": "string", "minLength": 1 }
              },
              "additionalProperties": true
            }
          },
          "defaultNextStepId": { "type": "string", "minLength": 1 }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "kind": { "const": "branch" }
              }
            },
            "then": {
              "required": ["branches"]
            }
          }
        ],
        "additionalProperties": true
      }
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": true
}
