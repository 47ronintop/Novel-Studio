{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "schema.agent-config.v1",
  "title": "Agent Config",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "type",
    "title",
    "status",
    "agentRole",
    "promptTemplateId",
    "inputSchemaId",
    "outputSchemaId",
    "modelProfileId",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "id": { "type": "string", "pattern": "^agent_[A-Za-z0-9_-]+$" },
    "type": { "const": "agent.config" },
    "title": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["active", "draft", "archived", "deleted"] },
    "agentRole": { "type": "string", "minLength": 1 },
    "promptTemplateId": { "type": "string" },
    "inputSchemaId": { "type": "string" },
    "outputSchemaId": { "type": "string" },
    "modelProfileId": { "type": "string" },
    "tools": { "type": "array", "items": { "type": "object" } },
    "limits": {
      "type": "object",
      "properties": {
        "maxRetries": { "type": "integer", "minimum": 0 },
        "timeoutMs": { "type": "integer", "minimum": 1000 }
      },
      "additionalProperties": true
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": true
}
