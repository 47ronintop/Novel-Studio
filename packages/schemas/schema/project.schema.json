{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "schema.project.v1",
  "title": "Novel Studio Project Metadata",
  "type": "object",
  "required": [
    "schemaVersion",
    "projectId",
    "title",
    "projectType",
    "language",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "projectId": { "type": "string", "pattern": "^prj_[A-Za-z0-9_-]+$" },
    "title": { "type": "string", "minLength": 1 },
    "projectType": {
      "type": "string",
      "enum": ["novel", "screenplay", "comic-script", "game-narrative"]
    },
    "language": { "type": "string", "minLength": 2 },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "defaultWorkflowId": { "type": "string" },
    "defaultModelProfileId": { "type": "string" },
    "stats": {
      "type": "object",
      "properties": {
        "targetWordCount": { "type": "integer", "minimum": 0 },
        "currentWordCount": { "type": "integer", "minimum": 0 },
        "chapterCount": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
