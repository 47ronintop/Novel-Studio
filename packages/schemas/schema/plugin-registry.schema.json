{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "schema.plugin-registry.v1",
  "title": "Novel Studio Plugin Registry",
  "type": "object",
  "required": ["schemaVersion", "plugins"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "plugins": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["pluginId", "enabled", "manifestPath", "grantedPermissions"],
        "properties": {
          "pluginId": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*(\\.[a-z0-9][a-z0-9-]*)+$"
          },
          "enabled": { "type": "boolean" },
          "manifestPath": { "type": "string", "pattern": "^plugins/[^/]+/plugin\\.json$" },
          "grantedPermissions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["permission", "scopes"],
              "properties": {
                "permission": {
                  "type": "string",
                  "enum": ["project:read", "asset:read", "asset:write", "workflow:invoke"]
                },
                "scopes": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "enum": [
                      "project",
                      "chapters",
                      "characters",
                      "world",
                      "outline",
                      "timeline",
                      "memories"
                    ]
                  },
                  "uniqueItems": true
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
