{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "schema.context-bundle.v1",
  "title": "Context Bundle",
  "type": "object",
  "required": ["schemaVersion", "contextBundleId", "workflowRunId", "budget", "items", "trace"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "contextBundleId": { "type": "string", "pattern": "^ctx_[A-Za-z0-9_-]+$" },
    "workflowRunId": { "type": "string" },
    "budget": {
      "type": "object",
      "required": ["maxTokens"],
      "properties": {
        "maxTokens": { "type": "integer", "minimum": 1 },
        "estimatedTokens": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["refType", "refId", "content", "tokenEstimate"],
        "properties": {
          "refType": { "type": "string" },
          "refId": { "type": "string" },
          "content": { "type": "string" },
          "tokenEstimate": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": true
      }
    },
    "trace": {
      "type": "object",
      "required": ["selectionReason", "excludedRefs"],
      "properties": {
        "selectionReason": { "type": "string" },
        "excludedRefs": { "type": "array", "items": { "type": "object" } }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
