{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://novel-studio.local/schemas/workflow-run-record.schema.json",
  "title": "Novel Studio Workflow Run Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "workflowRunId",
    "workflowId",
    "workflowTitle",
    "status",
    "startedAt",
    "updatedAt",
    "context",
    "model",
    "usage",
    "steps"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "workflowRunId": {
      "type": "string",
      "minLength": 1
    },
    "workflowId": {
      "type": "string",
      "minLength": 1
    },
    "workflowTitle": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": ["pending-confirmation", "applied", "failed"]
    },
    "startedAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "context": {
      "$ref": "#/$defs/contextSummary"
    },
    "model": {
      "$ref": "#/$defs/modelSummary"
    },
    "usage": {
      "$ref": "#/$defs/usageSummary"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/step"
      }
    },
    "error": {
      "$ref": "#/$defs/errorSummary"
    },
    "retryPolicy": {
      "$ref": "#/$defs/retryPolicy"
    }
  },
  "$defs": {
    "contextSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceCount", "tokenEstimate", "selectionReason"],
      "properties": {
        "sourceCount": {
          "type": "integer",
          "minimum": 0
        },
        "tokenEstimate": {
          "type": "integer",
          "minimum": 0
        },
        "selectionReason": {
          "type": "string"
        }
      }
    },
    "modelSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profileId", "displayName", "provider", "modelName"],
      "properties": {
        "profileId": {
          "type": "string",
          "minLength": 1
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "modelName": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "usageSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["inputTokens", "outputTokens", "totalTokens", "usageStatus", "cost"],
      "properties": {
        "inputTokens": {
          "type": "integer",
          "minimum": 0
        },
        "outputTokens": {
          "type": "integer",
          "minimum": 0
        },
        "totalTokens": {
          "type": "integer",
          "minimum": 0
        },
        "usageStatus": {
          "enum": ["missing", "estimated", "actual"]
        },
        "cost": {
          "type": "object",
          "additionalProperties": false,
          "required": ["amount", "currency", "status"],
          "properties": {
            "amount": {
              "type": "number",
              "minimum": 0
            },
            "currency": {
              "type": "string",
              "minLength": 1
            },
            "status": {
              "enum": ["unknown", "estimated", "actual"]
            }
          }
        }
      }
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stepId", "label", "kind", "status"],
      "properties": {
        "stepId": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "enum": ["context", "agent", "confirmation"]
        },
        "status": {
          "enum": ["pending", "running", "completed", "waiting-confirmation", "failed"]
        }
      }
    },
    "errorSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "recoverability": {
          "enum": ["retryable", "user-action", "fatal", "unknown"]
        },
        "suggestedAction": {
          "type": "string",
          "minLength": 1
        },
        "retryable": {
          "type": "boolean"
        }
      }
    },
    "retryPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "maxAttempts", "backoffLabel", "retryableCodes"],
      "properties": {
        "mode": {
          "enum": ["manual"]
        },
        "maxAttempts": {
          "type": "integer",
          "minimum": 1
        },
        "backoffLabel": {
          "type": "string",
          "minLength": 1
        },
        "retryableCodes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
